htmlcov/
.tox/
.nosexy
.noseids
.pytest_cache/
.mypy_cache/
.ruff_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.stats
.coverage
.coverage.*

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version if you
#   want to lock the version. Developer preference.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing pipenv install --dev, you may ignore it.
#Pipfile.lock

# poetry
#   According to poetry documentation, poetry.lock should be committed.
#poetry.lock

# pdm
#   According to pdm documentation, pdm.lock should be committed.
#.pdm-python.plugins
#pdm.lock

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

